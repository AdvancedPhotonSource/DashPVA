}

QPushButton {
    background-color: #FFFFFF;
    color: #1B2333;
    border: 1px solid #E0E4EB;
    border-radius: 7px;
    padding: 9px 14px;
    font-size: 13px;
    font-weight: 500;
    text-align: left;
}

QPushButton:hover {
    background-color: #EBF0FF;
    border-color: #4B6EF5;
    color: #2E52D5;
}

QPushButton:pressed {
    background-color: #D6E2FF;
    border-color: #3A5EE5;
}

QPushButton:disabled {
    background-color: #EBF0FF;
    border-color: #A8C0F0;
    color: #4B6EF5;
}

QPushButton#btn_settings {
    background: transparent;
    color: #5B6474;
    border: 1px solid #D8DCE5;
    border-radius: 6px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: normal;
    text-align: center;
}

QPushButton#btn_settings:hover {
    background-color: #ECEEF2;
    color: #1B2333;
    border-color: #B8BDC8;
}

QPushButton#btn_shutdown_all {
    background: transparent;
    color: #C2550A;
    border: 1px solid #FBCFB0;
    border-radius: 6px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: normal;
    text-align: center;
}

QPushButton#btn_shutdown_all:hover {
    background-color: #FFF4EE;
    border-color: #F5A77A;
}

QPushButton#btn_shutdown_all:disabled {
    color: #C4C9D2;
    border-color: #E8ECF0;
}

QPushButton#btn_exit {
    background-color: #E83535;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 5px 18px;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
}

QPushButton#btn_exit:hover {
