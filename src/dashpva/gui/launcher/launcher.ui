  <property name="styleSheet">
   <string notr="true">
QDialog {
    background-color: palette(window);
}

QLabel#lbl_header {
    font-size: 17pt;
    font-weight: 700;
    color: palette(window-text);
}

QLabel#lbl_subtitle {
    font-size: 10pt;
    color: palette(dark);
}

QLabel#lbl_status {
    font-size: 9pt;
    color: palette(dark);
}


QPushButton {
    background-color: palette(button);
    color: palette(button-text);
    border: 1px solid palette(mid);
    border-radius: 7px;
    padding: 9px 14px;
    font-size: 10pt;
    font-weight: 500;
    text-align: left;
}

QPushButton:hover {
    background-color: palette(highlight);
    border-color: palette(highlight);
    color: palette(highlighted-text);
}

QPushButton:pressed {
    background-color: palette(dark);
    border-color: palette(highlight);
}

QPushButton:disabled {
    background-color: palette(midlight);
    border-color: palette(mid);
    color: palette(dark);
}

QPushButton#btn_settings {
    background: transparent;
    color: palette(window-text);
    border: 1px solid palette(dark);
    border-radius: 6px;
    padding: 5px 14px;
    font-size: 10pt;
    font-weight: normal;
    text-align: center;
}

QPushButton#btn_settings:hover {
    background-color: palette(midlight);
    color: palette(window-text);
    border-color: palette(dark);
}

QPushButton#btn_shutdown_all {
    background: transparent;
    color: #E8600A;
    border: 1px solid #FBCFB0;
    border-radius: 6px;
    padding: 5px 14px;
    font-size: 10pt;
    font-weight: normal;
    text-align: center;
}

QPushButton#btn_shutdown_all:hover {
    background-color: palette(midlight);
    border-color: #F5A77A;
}

QPushButton#btn_shutdown_all:disabled {
    color: palette(dark);
    border-color: palette(mid);
}

QPushButton#btn_exit {
    background-color: #E83535;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 5px 18px;
    font-size: 10pt;
    font-weight: 600;
    text-align: center;
}

QPushButton#btn_exit:hover {
    background-color: #D12B2B;
}

QPushButton#btn_exit:pressed {
    background-color: #B82020;
}
   </string>
